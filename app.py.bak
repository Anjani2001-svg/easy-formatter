# ─── Constants ────────────────────────────────────────────────────────────────
WNS = "http://schemas.openxmlformats.org/wordprocessingml/2006/main"
RNS = "http://schemas.openxmlformats.org/officeDocument/2006/relationships"
CT_NS = "http://schemas.openxmlformats.org/package/2006/content-types"
def wt(tag): return "{" + WNS + "}" + tag

STYLE_FILES = [
    "word/styles.xml", "word/theme/theme1.xml", "word/theme/theme2.xml",
    "word/fontTable.xml", "word/numbering.xml", "word/settings.xml",
]

# Cover section: body[0]=cover image, body[1]=text box, body[2..12]=blanks/TOC, body[13]=section break
COVER_SECTION_LEN = 14   # elements 0-13 inclusive
# rId for cover image in template
COVER_IMAGE_RID = "rId8"
COVER_IMAGE_FILE = "media/image1.jpg"
# Footer rel IDs: rId9=even(footer1), rId10=odd/default(footer2)
FOOTER_EVEN_RID    = "rId9"
FOOTER_ODD_RID     = "rId10"
FOOTER_EVEN_FILE   = "footer1.xml"
FOOTER_ODD_FILE    = "footer2.xml"

def extract_docx(b, d):
    with zipfile.ZipFile(io.BytesIO(b)) as z: z.extractall(d)

def pack_docx(src):
    buf = io.BytesIO()
    with zipfile.ZipFile(buf, "w", zipfile.ZIP_DEFLATED) as z:
        for rd, _, files in os.walk(src):
            for fn in files:
                fp = os.path.join(rd, fn)
                z.write(fp, os.path.relpath(fp, src))
    return buf.getvalue()

def register_ns():
    for p, u in [
        ("w", WNS), ("r", RNS),
        ("wp", "http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing"),
        ("a",  "http://schemas.openxmlformats.org/drawingml/2006/main"),
        ("pic","http://schemas.openxmlformats.org/drawingml/2006/picture"),
        ("wps","http://schemas.microsoft.com/office/word/2010/wordprocessingShape"),
        ("mc", "http://schemas.openxmlformats.org/markup-compatibility/2006"),
        ("w14","http://schemas.microsoft.com/office/word/2010/wordml"),
        ("w15","http://schemas.microsoft.com/office/word/2012/wordml"),
        ("wpc","http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas"),
        ("wne","http://schemas.microsoft.com/office/word/2006/wordml"),
        ("",   CT_NS),
    ]: ET.register_namespace(p, u)

def make_footer_xml(course_name, page_on_right=True):
    """
    page_on_right=True  -> ODD pages:  © SLC [tab] course [tab] PAGE
    page_on_right=False -> EVEN pages: PAGE [tab] course [tab] © SLC
    Tab centre=4680, right=9360 (US Letter, 1-inch margins)
    """
    page_field = (
        '<w:r><w:rPr><w:sz w:val="18"/><w:szCs w:val="18"/></w:rPr><w:fldChar w:fldCharType="begin"/></w:r>'
        '<w:r><w:rPr><w:sz w:val="18"/><w:szCs w:val="18"/></w:rPr>'
        '<w:instrText xml:space="preserve"> PAGE \\* MERGEFORMAT </w:instrText></w:r>'
        '<w:r><w:rPr><w:sz w:val="18"/><w:szCs w:val="18"/></w:rPr><w:fldChar w:fldCharType="separate"/></w:r>'
        '<w:r><w:rPr><w:sz w:val="18"/><w:szCs w:val="18"/></w:rPr><w:t>1</w:t></w:r>'
        '<w:r><w:rPr><w:sz w:val="18"/><w:szCs w:val="18"/></w:rPr><w:fldChar w:fldCharType="end"/></w:r>'
    )
    sep   = '<w:r><w:rPr><w:sz w:val="16"/><w:szCs w:val="16"/></w:rPr><w:t xml:space="preserve"> | Page</w:t></w:r>'
    cn    = course_name.replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")
    slc   = '<w:r><w:rPr><w:sz w:val="16"/><w:szCs w:val="16"/></w:rPr><w:t>\u00a9 South London College Ltd</w:t></w:r>'
    crs   = ('<w:r><w:rPr><w:sz w:val="16"/><w:szCs w:val="16"/></w:rPr>'
             '<w:t xml:space="preserve">' + cn + '</w:t></w:r>')
    tab   = '<w:r><w:tab/></w:r>'
    body  = (slc + tab + crs + tab + page_field + sep) if page_on_right else (page_field + sep + tab + crs + tab + slc)
    return (
        '<?xml version="1.0" encoding="UTF-8" standalone="yes"?>'
        '<w:ftr xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main">'
        '<w:p><w:pPr>'
        '<w:pStyle w:val="Footer"/>'
        '<w:pBdr><w:top w:val="single" w:sz="24" w:space="1" w:color="1A99A0"/></w:pBdr>'
        '<w:tabs>'
        '<w:tab w:val="center" w:pos="4680"/>'
        '<w:tab w:val="right"  w:pos="9360"/>'
        '</w:tabs>'
        '</w:pPr>' + body + '</w:p></w:ftr>'
    )

def update_cover_text(cover_para, awarding_body, course_name, chapter):
    """
    body[1] has one text box with 3 paragraphs:
      para[0] = awarding_body
      para[1] = course_name
      para[2] = chapter
    Updates the first text box only (second is alternate content fallback).
    """
    fields = [awarding_body, course_name, chapter]
    txbx_seen = 0
    for txbx in cover_para.iter(wt("txbxContent")):
        ps = [p for p in list(txbx) if p.tag == wt("p")]
        for pi, para in enumerate(ps):
            if pi >= len(fields): continue
            t_els = list(para.iter(wt("t")))
            for i, tel in enumerate(t_els):
                tel.text = fields[pi] if i == 0 else ""
                tel.set("{http://www.w3.org/XML/1998/namespace}space", "preserve")
        txbx_seen += 1
        if txbx_seen >= 2: break  # first two textboxes (main + alternate content)

def add_bullets_to_references(out_body):
    """Find References heading (any style) by text and bullet all following paragraphs."""
    in_refs = False
    changed = 0
    for para in list(out_body):
        if para.tag != wt("p"): continue
        texts = "".join(t.text or "" for t in para.iter(wt("t"))).strip()
        pPr = para.find(wt("pPr"))
        pStyle = pPr.find(wt("pStyle")) if pPr is not None else None
        style_val = pStyle.get(wt("val"), "") if pStyle is not None else ""

        if texts == "References":
            in_refs = True
            continue
        if in_refs:
            # Stop at next heading-like style
            if style_val.startswith("Heading") or style_val.startswith("Style") or style_val == "TOC-Heading":
                break
            if not texts: continue
            if pPr is None:
                pPr = ET.Element(wt("pPr"))
                para.insert(0, pPr)
            if pStyle is None:
                pStyle = ET.Element(wt("pStyle"))
                pPr.insert(0, pStyle)
            pStyle.set(wt("val"), "ListParagraph")
            existing = pPr.find(wt("numPr"))
            if existing is not None: pPr.remove(existing)
            numPr = ET.Element(wt("numPr"))
            iv = ET.SubElement(numPr, wt("ilvl")); iv.set(wt("val"), "0")
            ni = ET.SubElement(numPr, wt("numId")); ni.set(wt("val"), "12")
            pPr.insert(1, numPr)
            changed += 1
    return changed

def inject_footer_into_sectPr(sPr):
    """Add evenAndOddHeaders + both footer refs to any sectPr element."""
    for fr in sPr.findall(wt("footerReference")): sPr.remove(fr)
    for el in sPr.findall(wt("evenAndOddHeaders")): sPr.remove(el)
    sPr.insert(0, ET.Element(wt("evenAndOddHeaders")))
    fr_e = ET.Element(wt("footerReference"))
    fr_e.set(wt("type"), "even");    fr_e.set("{" + RNS + "}id", FOOTER_EVEN_RID)
    fr_o = ET.Element(wt("footerReference"))
    fr_o.set(wt("type"), "default"); fr_o.set("{" + RNS + "}id", FOOTER_ODD_RID)
    sPr.insert(1, fr_e); sPr.insert(2, fr_o)

def process(target_bytes, cover_img_bytes, cover_img_ext,
            awarding_body, course_name, chapter):
    template_bytes = get_template_bytes()
    with tempfile.TemporaryDirectory() as tmp:
        tmpl = os.path.join(tmp, "tmpl")
        out  = os.path.join(tmp, "out")
        os.makedirs(tmpl); os.makedirs(out)
        extract_docx(template_bytes, tmpl)
        extract_docx(target_bytes,   out)
        register_ns()
        log = []

        # 1. Copy style/theme/numbering/settings files from template
        for rp in STYLE_FILES:
            src = os.path.join(tmpl, rp); dst = os.path.join(out, rp)
            if os.path.exists(src):
                os.makedirs(os.path.dirname(dst), exist_ok=True)
                shutil.copy2(src, dst)
        log.append("\u2714 Styles, fonts, numbering, theme applied")

        # 1b. Add bullet abstractNum+num to numbering.xml (template has none)
        num_path = os.path.join(out, "word", "numbering.xml")
        if os.path.exists(num_path):
            num_tree = ET.parse(num_path); num_root = num_tree.getroot()
            existing_abs = {el.get(wt("abstractNumId")) for el in num_root.findall(wt("abstractNum"))}
            existing_nums = {el.get(wt("numId")) for el in num_root.findall(wt("num"))}
            if "11" not in existing_abs:
                aNum = ET.SubElement(num_root, wt("abstractNum")); aNum.set(wt("abstractNumId"), "11")
                ET.SubElement(aNum, wt("multiLevelType")).set(wt("val"), "singleLevel")
                lvl = ET.SubElement(aNum, wt("lvl")); lvl.set(wt("ilvl"), "0")
                ET.SubElement(lvl, wt("start")).set(wt("val"), "1")
                ET.SubElement(lvl, wt("numFmt")).set(wt("val"), "bullet")
                ET.SubElement(lvl, wt("lvlText")).set(wt("val"), "\u2022")
                ET.SubElement(lvl, wt("lvlJc")).set(wt("val"), "left")
                pPr_lvl = ET.SubElement(lvl, wt("pPr"))
                ind = ET.SubElement(pPr_lvl, wt("ind")); ind.set(wt("left"), "720"); ind.set(wt("hanging"), "360")
                # No font override — use document default font so bullet renders as round •
            if "12" not in existing_nums:
                numEl = ET.SubElement(num_root, wt("num")); numEl.set(wt("numId"), "12")
                ET.SubElement(numEl, wt("abstractNumId")).set(wt("val"), "11")
            num_tree.write(num_path, xml_declaration=True, encoding="UTF-8")

        # 1c. Patch styles.xml: Garamond font everywhere + blue on H2/H3 + A4 page size
        styles_path = os.path.join(out, "word", "styles.xml")
        if os.path.exists(styles_path):
            st_tree = ET.parse(styles_path)
            st_root = st_tree.getroot()

            GARAMOND = "Garamond"
            BLUE     = "2E74B5"   # Word standard heading blue

            # Helper: ensure rPr exists on a style element
            def get_rPr(style_el):
                rp = style_el.find(wt("rPr"))
                if rp is None:
                    rp = ET.SubElement(style_el, wt("rPr"))
                return rp

            # 1. docDefaults — remove theme font, set Garamond
            dd_rFonts = st_root.find(".//" + wt("docDefaults") + "//" + wt("rFonts"))
            if dd_rFonts is not None:
                for attr in list(dd_rFonts.attrib):
                    del dd_rFonts.attrib[attr]
                dd_rFonts.set(wt("ascii"),    GARAMOND)
                dd_rFonts.set(wt("hAnsi"),    GARAMOND)
                dd_rFonts.set(wt("eastAsia"), GARAMOND)
                dd_rFonts.set(wt("cs"),       GARAMOND)

            # 2. Per-style: set Garamond on all named styles; set blue on H2/H3
            HEADING_STYLES = {"Heading2", "Heading3"}
            for style_el in st_root.findall(wt("style")):
                sid = style_el.get(wt("styleId"), "")
                rp  = get_rPr(style_el)

                # Set Garamond
                rf = rp.find(wt("rFonts"))
                if rf is None:
                    rf = ET.SubElement(rp, wt("rFonts"))
                for attr in list(rf.attrib):
                    del rf.attrib[attr]
                rf.set(wt("ascii"),    GARAMOND)
                rf.set(wt("hAnsi"),    GARAMOND)
                rf.set(wt("eastAsia"), GARAMOND)
                rf.set(wt("cs"),       GARAMOND)

                # Set blue colour for Heading2 and Heading3
                if sid in HEADING_STYLES:
                    col = rp.find(wt("color"))
                    if col is None:
                        col = ET.SubElement(rp, wt("color"))
                    col.set(wt("val"), BLUE)

            st_tree.write(styles_path, xml_declaration=True, encoding="UTF-8")
            log.append(f"\u2714 Fonts set to Garamond | Heading 2 & 3 → blue (#{BLUE})")

        # 2. Write fresh footer XML files (even=page left, odd=page right)
        word_out = os.path.join(out, "word")
        with open(os.path.join(word_out, FOOTER_EVEN_FILE), "w", encoding="utf-8") as f:
            f.write(make_footer_xml(course_name, page_on_right=False))   # EVEN
        with open(os.path.join(word_out, FOOTER_ODD_FILE), "w", encoding="utf-8") as f:
            f.write(make_footer_xml(course_name, page_on_right=True))    # ODD
        log.append(f"\u2714 Footers: odd=page right | even=page left | course: \"{course_name}\"")

        # 3. Register footer content types (target doc may not have them)
        ct_path = os.path.join(out, "[Content_Types].xml")
        ET.register_namespace("", CT_NS)
        ct_tree = ET.parse(ct_path); ct_root = ct_tree.getroot()
        FOOTER_CT = "application/vnd.openxmlformats-officedocument.wordprocessingml.footer+xml"
        existing_parts = {el.get("PartName") for el in ct_root}
        for part in ["/word/" + FOOTER_EVEN_FILE, "/word/" + FOOTER_ODD_FILE]:
            if part not in existing_parts:
                el = ET.SubElement(ct_root, "{" + CT_NS + "}Override")
                el.set("PartName", part); el.set("ContentType", FOOTER_CT)
        ct_tree.write(ct_path, xml_declaration=True, encoding="UTF-8")
        log.append("\u2714 Footer content types registered")

        # 4. Parse documents
        tmpl_tree = ET.parse(os.path.join(tmpl, "word/document.xml"))
        out_tree  = ET.parse(os.path.join(out,  "word/document.xml"))
        tmpl_body = tmpl_tree.getroot().find(wt("body"))
        out_body  = out_tree.getroot().find(wt("body"))

        # 5. Update cover text (body[1] in template = text box para)
        tmpl_paras = list(tmpl_body)
        cover_textbox_para = tmpl_paras[1]
        update_cover_text(copy.deepcopy(cover_textbox_para), awarding_body, course_name, chapter)
        # We'll use this updated version when we copy the cover section below
        log.append("\u2714 Cover page text updated")

        # 6. Cover image
        media_out = os.path.join(out, "word", "media"); os.makedirs(media_out, exist_ok=True)
        rels_path = os.path.join(out, "word", "_rels", "document.xml.rels")
        rels_tree = ET.parse(rels_path); rels_root = rels_tree.getroot()
        ANS = "http://schemas.openxmlformats.org/drawingml/2006/main"

        if cover_img_bytes:
            ext = (cover_img_ext or "jpg").lstrip(".")
            new_fname = "cover_custom." + ext
            with open(os.path.join(media_out, new_fname), "wb") as f: f.write(cover_img_bytes)
            new_rid = "rIdCoverCustom"
            # We'll fix up blip rId after copying cover section
            for r in list(rels_root):
                if r.get("Id") == new_rid: rels_root.remove(r)
            ET.SubElement(rels_root, "Relationship", {
                "Id": new_rid, "Type": RNS + "/image", "Target": "media/" + new_fname})
            cover_img_rid = new_rid
            log.append("\u2714 Custom cover image applied")
        else:
            # Copy default cover image from template
            src_img = os.path.join(tmpl, "word", COVER_IMAGE_FILE)
            dst_img = os.path.join(out,  "word", COVER_IMAGE_FILE)
            if os.path.exists(src_img): shutil.copy2(src_img, dst_img)
            # Copy any other media from template (logos etc)
            for mf in os.listdir(os.path.join(tmpl, "word", "media")):
                src_m = os.path.join(tmpl, "word", "media", mf)
                dst_m = os.path.join(out,  "word", "media", mf)
                if not os.path.exists(dst_m): shutil.copy2(src_m, dst_m)
            if not any(r.get("Id") == COVER_IMAGE_RID for r in rels_root):
                ET.SubElement(rels_root, "Relationship", {
                    "Id": COVER_IMAGE_RID, "Type": RNS + "/image", "Target": COVER_IMAGE_FILE})
            # Also register other image rels from template
            tmpl_rels = ET.parse(os.path.join(tmpl, "word", "_rels", "document.xml.rels"))
            existing_ids = {r.get("Id") for r in rels_root}
            for r in tmpl_rels.getroot():
                if r.get("Type", "").endswith("/image") and r.get("Id") not in existing_ids:
                    ET.SubElement(rels_root, "Relationship", {
                        "Id": r.get("Id"), "Type": r.get("Type"), "Target": r.get("Target")})
            cover_img_rid = None
            log.append("\u2714 Default cover image kept")

        # 7. Add footer rels to output document rels
        for rid, fname in [(FOOTER_EVEN_RID, FOOTER_EVEN_FILE), (FOOTER_ODD_RID, FOOTER_ODD_FILE)]:
            for r in list(rels_root):
                if r.get("Id") == rid: rels_root.remove(r)
            ET.SubElement(rels_root, "Relationship", {
                "Id": rid, "Type": RNS + "/footer", "Target": fname})
        rels_tree.write(rels_path, xml_declaration=True, encoding="UTF-8")
        log.append("\u2714 Footer relationships registered")

        # 8. Build updated cover section from template (body[0..13])
        #    body[0] = cover image, body[1] = text box, body[13] = section break
        cover_elements = []
        for i, el in enumerate(tmpl_paras[:COVER_SECTION_LEN]):
            el_copy = copy.deepcopy(el)
            if i == 1:
                # Apply text field updates to text box para
                update_cover_text(el_copy, awarding_body, course_name, chapter)
            if i == 0 and cover_img_rid:
                # Replace cover image rId with custom one
                for blip in el_copy.iter("{" + ANS + "}blip"):
                    if blip.get("{" + RNS + "}embed") == COVER_IMAGE_RID:
                        blip.set("{" + RNS + "}embed", cover_img_rid)
            cover_elements.append(el_copy)

        # 8b. Insert section break after cover image+textbox (index 1)
        #     Section A (body[0..new_break]) = cover image — no footer
        #     Section B (body[new_break+1..orig_13]) = TOC — gets footer injected below, page starts at 1
        cib = ET.Element(wt("p"))
        cib_pPr = ET.SubElement(cib, wt("pPr"))
        cib_sPr = ET.SubElement(cib_pPr, wt("sectPr"))
        pgSz_c = ET.SubElement(cib_sPr, wt("pgSz")); pgSz_c.set(wt("w"),"11906"); pgSz_c.set(wt("h"),"16838")
        pgMar_c = ET.SubElement(cib_sPr, wt("pgMar"))
        for a,v in [("top","1440"),("right","1440"),("bottom","1440"),("left","1440"),("header","720"),("footer","720"),("gutter","0")]:
            pgMar_c.set(wt(a), v)
        cover_elements.insert(2, cib)  # [0]=img, [1]=textbox, [2]=new break, [3..14]=TOC/blanks/orig break

        # 9. Remove existing cover-like content from output, prepend cover section
        while list(out_body) and out_body[0].find(".//" + wt("drawing")) is not None:
            out_body.remove(out_body[0])
        for el in reversed(cover_elements):
            out_body.insert(0, el)
        log.append("\u2714 Full cover section injected (cover page clean, TOC page 1)")

        # 10. Inject footer refs into ALL sectPr elements (inline + body-level)
        #     Skip the very first sectPr (body[13] = cover section break — no footer on cover)
        cover_sect_passed = False
        for para in list(out_body):
            # Inline sectPr (p > pPr > sectPr)
            if para.tag == wt("p"):
                pPr2 = para.find(wt("pPr"))
                if pPr2 is not None:
                    sPr = pPr2.find(wt("sectPr"))
                    if sPr is not None:
                        if not cover_sect_passed:
                            cover_sect_passed = True  # skip cover section break
                        else:
                            inject_footer_into_sectPr(sPr)
                            # Ensure this content section restarts page numbering at 1
                            existing_pgNum = sPr.find(wt("pgNumType"))
                            if existing_pgNum is not None: sPr.remove(existing_pgNum)
                            pgNum_el = ET.Element(wt("pgNumType"))
                            pgNum_el.set(wt("start"), "1")
                            sPr.append(pgNum_el)
            # Direct body-level sectPr
            elif para.tag == wt("sectPr"):
                inject_footer_into_sectPr(para)
                pgNum_el2 = ET.Element(wt("pgNumType"))
                pgNum_el2.set(wt("start"), "1")
                existing = para.find(wt("pgNumType"))
                if existing is not None: para.remove(existing)
                para.append(pgNum_el2)

        log.append("\u2714 Footer refs + odd/even headers activated in all sections")

        # 10b. Set A4 page size on ALL sectPr elements in output document
        for child in list(out_body):
            sectPr_list = []
            if child.tag == wt("sectPr"):
                sectPr_list.append(child)
            elif child.tag == wt("p"):
                pPr2 = child.find(wt("pPr"))
                if pPr2 is not None:
                    sPr = pPr2.find(wt("sectPr"))
                    if sPr is not None: sectPr_list.append(sPr)
            for sPr in sectPr_list:
                pgSz = sPr.find(wt("pgSz"))
                if pgSz is None: pgSz = ET.SubElement(sPr, wt("pgSz"))
                pgSz.set(wt("w"), "11906"); pgSz.set(wt("h"), "16838")
                # Adjust margins for A4 (keep 1 inch all around)
                pgMar = sPr.find(wt("pgMar"))
                if pgMar is None: pgMar = ET.SubElement(sPr, wt("pgMar"))
                for a,v in [("top","1440"),("right","1440"),("bottom","1440"),
                            ("left","1440"),("header","720"),("footer","720"),("gutter","0")]:
                    pgMar.set(wt(a), v)
        log.append("\u2714 Page size set to A4 (210 × 297mm)")

        # 11. Add bullets to References section
        bullets_added = add_bullets_to_references(out_body)
        if bullets_added:
            log.append(f"\u2714 Bullets added to {bullets_added} reference entries")

        out_tree.write(os.path.join(out, "word/document.xml"),
                       xml_declaration=True, encoding="UTF-8", short_empty_elements=True)
        return pack_docx(out), log


# ── Step 4: Generate ──────────────────────────────────────────────────────────
st.markdown('<div class="step-row"><span class="badge">4</span> Generate Formatted Document</div>', unsafe_allow_html=True)

if target_file:
    if st.button("\u26a1 Apply Format & Generate"):
        with st.spinner("Formatting document\u2026"):
            try:
                img_bytes = None; img_ext = "jpg"
                if cover_img_file:
                    img_bytes = cover_img_file.read()
                    img_ext   = Path(cover_img_file.name).suffix
                result_bytes, log = process(
                    target_file.read(), img_bytes, img_ext,
                    awarding_body, course_name, chapter
                )
                st.markdown("### \u2705 Document ready!")
                for item in log:
                    st.markdown('<div class="ritem">' + item + '</div>', unsafe_allow_html=True)
                out_name = Path(target_file.name).stem + "_SLC_formatted.docx"
                st.download_button(
                    label="\u2b07\ufe0f  Download " + out_name,
                    data=result_bytes, file_name=out_name,
                    mime="application/vnd.openxmlformats-officedocument.wordprocessingml.document"
                )
            except Exception as e:
                st.error("Error: " + str(e)); st.exception(e)
else:
    st.markdown('<div style="text-align:center;color:#bbb;padding:1.5rem 0;">\U0001f446 Complete the steps above to generate your document.</div>', unsafe_allow_html=True)

st.markdown("<hr>", unsafe_allow_html=True)
